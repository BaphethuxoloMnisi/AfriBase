@{
    ViewData["Title"] = "Events";
}

<!-- Fonts & Styles -->
<link href="https://fonts.googleapis.com/css2?family=Ubuntu:wght@400;700&display=swap" rel="stylesheet">

<style>
    #font-face {
        font-family: 'Africola';
        src: url('/fonts/Africola.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
    }

    body {
        font-family: 'Ubuntu', sans-serif;
        background: url('/images/tribal.png') repeat;
        background-color: #fffaf0;
        color: #2c2c2c;
    }

    .african-heading {
        font-family: 'Africola', sans-serif;
        color: #d97706;
        font-size: 2rem;
        border-bottom: 4px solid #14532d;
        display: inline-block;
        padding-bottom: 6px;
        margin-bottom: 15px;
        letter-spacing: 1px;
    }

    .event-card {
        background-color: #fefce8;
        border: 2px solid #78350f;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 6px 6px 12px rgba(0, 0, 0, 0.1);
        height: 100%;
    }

    .event-title {
        font-family: 'Comic Sans MS', cursive;
        color: #78350f;
        font-size: 1.4rem;
        margin-bottom: 10px;
    }

    .event-text {
        font-size: 1.1rem;
        color: #374151;
    }

    .event-date {
        font-weight: bold;
        color: #1e293b;
    }
</style>

<!-- Content -->
<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="african-heading">Upcoming Events</h1>
        <p class="lead">Join us for our upcoming exhibitions and auctions celebrating African heritage.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-4">
        <div class="col">
            <div class="event-card">
                <h5 class="event-title">Ancient Treasures Exhibition</h5>
                <p class="event-text">Experience rare artifacts never seen before, from Egypt and Mesopotamia.</p>
                <p class="event-date">Date: June 15–30, 2025</p>
            </div>
        </div>

        <div class="col">
            <div class="event-card">
                <h5 class="event-title">Artifact Auction</h5>
                <p class="event-text">Place your bids on ancient coins, jewelry, and sculptures.</p>
                <p class="event-date">Date: July 10, 2025</p>
            </div>
        </div>
    </div>
</div>
