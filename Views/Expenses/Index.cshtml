@model IEnumerable<ExpenseTracker.Models.Expense>

@{
    ViewData["Title"] = "Expenses";
}

<h2>Artifacts</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Artifact</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Description</th>
            <th>Amount</th>
            <th>Date</th>
            <th>Details</th>
            <th>Edit</th>
            <th>Delete</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var expense in Model)
        {
            <tr>
                <td>@expense.Description</td>
                <td>@expense.Amount.ToString("C")</td>
                <td>@expense.Date.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@expense.Id" class="btn btn-info">Details</a>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-secondary">Edit</a>
                </td>
                <td>
                    <a asp-action="Delete" asp-route-id="@expense.Id" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>